# ─── Gray Art · Variáveis de Ambiente ────────────────────────────────────────
# Copie este arquivo para .env.local e preencha as credenciais reais.
# NUNCA commite .env.local com credenciais reais no git.
#
# ─── Como obter cada credencial ──────────────────────────────────────────────
#
# META (Instagram + Facebook)
# 1. Acesse: https://developers.facebook.com/apps/
# 2. Crie ou abra seu App → "App Settings" → "Basic"
# 3. Copie o "App ID" e gere um "App Secret"
# 4. Em "Products" adicione: "Facebook Login" + "Instagram Graph API"
# 5. Em Facebook Login → Settings → Valid OAuth Redirect URIs:
#    Adicione: https://www.flowgray.com.br/grayart/oauth/callback
#              http://localhost:5173/grayart/oauth/callback
# Permissões necessárias (solicitar na revisão do App):
#   instagram_basic, instagram_content_publish, instagram_manage_insights
#   pages_manage_posts, pages_read_engagement, pages_show_list
#
VITE_META_APP_ID=SEU_META_APP_ID_AQUI
VITE_META_APP_SECRET=SEU_META_APP_SECRET_AQUI

# ─── LinkedIn ───────────────────────────────────────────────────────────────
# 1. Acesse: https://www.linkedin.com/developers/apps
# 2. Crie App → associe a uma Company Page
# 3. Auth tab → Redirect URLs: https://www.flowgray.com.br/grayart/oauth/callback
# 4. Products: adicione "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# Scopes: w_member_social, r_liteprofile, r_organization_social, w_organization_social
#
VITE_LINKEDIN_CLIENT_ID=SEU_LINKEDIN_CLIENT_ID_AQUI
VITE_LINKEDIN_CLIENT_SECRET=SEU_LINKEDIN_CLIENT_SECRET_AQUI

# ─── TikTok ────────────────────────────────────────────────────────────────
# 1. Acesse: https://developers.tiktok.com/
# 2. Crie App → App Type: Web
# 3. Adicione: Login Kit + Content Posting API
# 4. Redirect URI: https://www.flowgray.com.br/grayart/oauth/callback
# Scopes: user.info.basic, video.upload, video.publish
#
VITE_TIKTOK_CLIENT_KEY=SEU_TIKTOK_CLIENT_KEY_AQUI
VITE_TIKTOK_CLIENT_SECRET=SEU_TIKTOK_CLIENT_SECRET_AQUI

# ─── YouTube / Google ──────────────────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com/
# 2. Crie Projeto → APIs & Services → Library → ative "YouTube Data API v3"
# 3. Credentials → Create Credentials → OAuth 2.0 Client IDs → Web Application
# 4. Authorized redirect URIs: https://www.flowgray.com.br/grayart/oauth/callback
# Scopes: youtube.upload, youtube.force-ssl
#
VITE_GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID_AQUI
VITE_GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET_AQUI

# ─── Pinterest ─────────────────────────────────────────────────────────────
# 1. Acesse: https://developers.pinterest.com/apps/
# 2. Crie App → My apps → Create app
# 3. Redirect URIs: https://www.flowgray.com.br/grayart/oauth/callback
# Scopes: boards:read, boards:write, pins:read, pins:write
#
VITE_PINTEREST_APP_ID=SEU_PINTEREST_APP_ID_AQUI
VITE_PINTEREST_APP_SECRET=SEU_PINTEREST_APP_SECRET_AQUI

# ─── Backend URL ───────────────────────────────────────────────────────────
# URL do backend que troca o `code` OAuth por `access_token`
# Em desenvolvimento: http://localhost:8080
# Em produção: https://api.flowgray.com.br
#
# ─── Google Gemini AI ─────────────────────────────────────────────────────
# 1. Acesse: https://aistudio.google.com/apikey
# 2. Crie uma API Key
# Usada para: geração de copy IA + prompts de vídeo Veo 3
#
VITE_GEMINI_API_KEY=SUA_GEMINI_API_KEY_AQUI

# ─── Evolution API (WhatsApp) ────────────────────────────────────────────
# URL e chave da Evolution API rodando no VPS
# Usada para: conexão WhatsApp via QR Code, disparo de mensagens
#
VITE_EVOLUTION_API_URL=http://SEU_VPS_IP:8080
VITE_EVOLUTION_API_KEY=SUA_EVOLUTION_API_KEY_AQUI

VITE_BACKEND_URL=http://localhost:8080
